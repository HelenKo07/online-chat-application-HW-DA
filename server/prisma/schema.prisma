generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
}

enum RoomRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  ownedRooms    Room[]    @relation("OwnedRooms")
  roomMemberships RoomMember[]
  messages      Message[]
  sentFriendRequests     FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestReceiver")
  friendshipsLow         Friendship[]    @relation("FriendshipLowUser")
  friendshipsHigh        Friendship[]    @relation("FriendshipHighUser")
  directChatsLow         DirectChat[]    @relation("DirectChatLowUser")
  directChatsHigh        DirectChat[]    @relation("DirectChatHighUser")
  directMessages         DirectMessage[]
  presence              UserPresence?
  roomReads             RoomRead[]
  directChatReads       DirectChatRead[]
  roomAttachments       RoomAttachment[]
  directAttachments     DirectAttachment[]
  roomBansReceived      RoomBan[]        @relation("RoomBanTarget")
  roomBansIssued        RoomBan[]        @relation("RoomBanIssuer")
  roomInvitationsReceived RoomInvitation[] @relation("RoomInvitationTarget")
  roomInvitationsIssued   RoomInvitation[] @relation("RoomInvitationIssuer")
  userBlocksReceived      UserBlock[]    @relation("UserBlockTarget")
  userBlocksIssued        UserBlock[]    @relation("UserBlockIssuer")
}

model Session {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  expiresAt     DateTime
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Room {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  visibility    RoomVisibility @default(PUBLIC)
  ownerId       String
  owner         User           @relation("OwnedRooms", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   RoomMember[]
  messages      Message[]
  attachments   RoomAttachment[]
  reads         RoomRead[]
  bans          RoomBan[]
  invitations   RoomInvitation[]

  @@index([visibility])
  @@index([ownerId])
}

model RoomBan {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  bannedById  String
  reason      String?
  createdAt   DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User     @relation("RoomBanTarget", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy    User     @relation("RoomBanIssuer", fields: [bannedById], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId, createdAt])
  @@index([userId])
}

model RoomInvitation {
  id            String   @id @default(cuid())
  roomId         String
  invitedUserId  String
  invitedById    String
  message        String?
  createdAt      DateTime @default(now())
  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invitedUser    User      @relation("RoomInvitationTarget", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy      User      @relation("RoomInvitationIssuer", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([roomId, invitedUserId])
  @@index([invitedUserId, createdAt])
  @@index([roomId, createdAt])
}

model RoomMember {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  role        RoomRole @default(MEMBER)
  joinedAt    DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  roomId     String
  authorId   String
  text       String
  replyToMessageId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyToMessage Message? @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies       Message[] @relation("MessageReply")

  @@index([roomId, createdAt])
  @@index([authorId])
  @@index([replyToMessageId])
}

model RoomAttachment {
  id            String   @id @default(cuid())
  roomId         String
  uploadedById   String
  originalName   String
  mimeType       String
  sizeBytes      Int
  storagePath    String
  comment        String?
  createdAt      DateTime @default(now())
  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  uploadedBy     User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([uploadedById])
}

model FriendRequest {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
}

model Friendship {
  id         String   @id @default(cuid())
  lowUserId  String
  highUserId String
  createdAt  DateTime @default(now())
  lowUser    User     @relation("FriendshipLowUser", fields: [lowUserId], references: [id], onDelete: Cascade)
  highUser   User     @relation("FriendshipHighUser", fields: [highUserId], references: [id], onDelete: Cascade)

  @@unique([lowUserId, highUserId])
  @@index([lowUserId])
  @@index([highUserId])
}

model UserBlock {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())
  blocker     User     @relation("UserBlockIssuer", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User     @relation("UserBlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId, createdAt])
  @@index([blockerId, createdAt])
}

model DirectChat {
  id         String          @id @default(cuid())
  lowUserId  String
  highUserId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  lowUser    User            @relation("DirectChatLowUser", fields: [lowUserId], references: [id], onDelete: Cascade)
  highUser   User            @relation("DirectChatHighUser", fields: [highUserId], references: [id], onDelete: Cascade)
  messages   DirectMessage[]
  attachments DirectAttachment[]
  reads      DirectChatRead[]

  @@unique([lowUserId, highUserId])
  @@index([lowUserId, updatedAt])
  @@index([highUserId, updatedAt])
}

model DirectMessage {
  id          String     @id @default(cuid())
  directChatId String
  authorId    String
  text        String
  replyToMessageId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  directChat  DirectChat @relation(fields: [directChatId], references: [id], onDelete: Cascade)
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyToMessage DirectMessage? @relation("DirectMessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies       DirectMessage[] @relation("DirectMessageReply")

  @@index([directChatId, createdAt])
  @@index([authorId])
  @@index([replyToMessageId])
}

model DirectAttachment {
  id            String    @id @default(cuid())
  directChatId  String
  uploadedById  String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  comment       String?
  createdAt     DateTime  @default(now())
  directChat    DirectChat @relation(fields: [directChatId], references: [id], onDelete: Cascade)
  uploadedBy    User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([directChatId, createdAt])
  @@index([uploadedById])
}

model UserPresence {
  userId       String   @id
  lastSeenAt   DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoomRead {
  id         String   @id @default(cuid())
  userId     String
  roomId     String
  lastReadAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([roomId])
}

model DirectChatRead {
  id           String     @id @default(cuid())
  userId       String
  directChatId String
  lastReadAt   DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  directChat   DirectChat @relation(fields: [directChatId], references: [id], onDelete: Cascade)

  @@unique([userId, directChatId])
  @@index([directChatId])
}
